# Google OAuth / NextAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://127.0.0.1:8080

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# If local API routes fail with "Cannot reach Supabase" / fetch failed, Node cannot
# reach the internet (common on corporate networks). Uncomment and set as needed,
# then restart `yarn dev`. Ask IT for proxy URL and CA bundle if unsure.
# HTTPS_PROXY=http://proxy.example.com:8080
# HTTP_PROXY=http://proxy.example.com:8080
# If logs show SELF_SIGNED_CERT_IN_CHAIN / "self-signed certificate in certificate chain",
# you need the corporate root CA PEM (not the Supabase URL — TLS inspection on your network):
# NODE_EXTRA_CA_CERTS=C:\path\to\organization-root-ca.pem

# Optional table override (defaults to users)
SUPABASE_USERS_TABLE=users
